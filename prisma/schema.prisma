generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  role            Role      @default(USER)
  name            String?
  avatarUrl       String?
  emailVerified   DateTime?
  verifyToken     String?
  resetToken      String?
  resetTokenExpiry DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  subscription    Subscription?
  skyCoinsBalance SkyCoinsBalance?
  transactions    Transaction[]
  purchases       Purchase[]
  messages        Message[]
  conversations   Conversation[]
  privateRequests PrivateRequest[]
  quotidirtyPurchases QuotidirtyPurchase[]
  manualPaymentRequests ManualPaymentRequest[]
  sessions        Session[]

  // Muses & Vault state
  activeMuseId      String?
  activeElixirId    String?
  activeMoodPackId  String?
  elixirExpiresAt   DateTime?
  vaultPIN          String?   // User's secret code for the Library
  musePurchases     MusePurchase[]
  
  // Chat Engagement
  totalSpentInChat Int      @default(0)
  lastSeenAt       DateTime @default(now())

  // Gamification & Loyalty
  totalSkyCoinsEarned Int   @default(0)
  dailyLogins         DailyLogin[]
  missionCompletions  MissionCompletion[]

  @@index([email])
}

// ... existing models ...

enum ThemeMode {
  LUMINA
  NOCTUA
}

model Muse {
  id              String        @id @default(cuid())
  title           String
  description     String
  prompt          String
  price           Int           // In SkyCoins
  category        MuseCategory
  isActive        Boolean       @default(true)
  imageUrl        String?
  backgroundImage String?
  mode            ThemeMode     @default(NOCTUA)
  
  // Personification Fields
  age            Int?
  bio            String?
  location       String?       @default("Milan, Italy")
  traits         String[]
  previewMessage String?       // Message preview shown on hover
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  purchases   MusePurchase[]
}

model MusePurchase {
  id        String   @id @default(cuid())
  userId    String
  museId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  muse      Muse     @relation(fields: [museId], references: [id], onDelete: Cascade)

  @@unique([userId, museId])
}

enum MuseCategory {
  MUSE
  ELIXIR
  RITUAL
  MOOD_PACK
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String             @unique
  tier      SubscriptionTier
  status    SubscriptionStatus @default(ACTIVE)
  stripeSubscriptionId String? @unique
  stripeCustomerId     String?
  currentPeriodStart   DateTime @default(now())
  currentPeriodEnd     DateTime
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeSubscriptionId])
}

model SkyCoinsBalance {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Transaction {
  id              String          @id @default(cuid())
  userId          String
  type            TransactionType
  amount          Int             // SkyCoins amount
  euroAmount      Float?          // EUR amount paid
  stripePaymentId String?         @unique
  description     String?
  createdAt       DateTime        @default(now())
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  contentId String
  price     Int      // SkyCoins price
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content  @relation(fields: [contentId], references: [id])

  @@unique([userId, contentId])
  @@index([userId])
}

model Content {
  id          String      @id @default(cuid())
  title       String
  description String?
  type        ContentType
  tier        SubscriptionTier
  price       Int         // SkyCoins price
  imageUrl    String?
  mediaUrl    String?
  isActive    Boolean     @default(true)
  mode        ThemeMode   @default(NOCTUA)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  purchases   Purchase[]

  @@index([type])
  @@index([tier])
}

model Message {
  id            String        @id @default(cuid())
  userId        String
  conversationId String
  content       String?
  sender        MessageSender
  messageType   MessageType   @default(TEXT)
  mediaUrl      String?
  isLocked      Boolean       @default(false)
  price         Int           @default(0) // In SkyCoins
  isPaid        Boolean       @default(false)
  isAI          Boolean       @default(true) // Was this generated by AI?
  
  createdAt     DateTime      @default(now())
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation  Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([conversationId])
  @@index([createdAt])
}

model Conversation {
  id            String    @id @default(cuid())
  userId        String    @unique
  lastMessageAt DateTime  @default(now())
  unreadCount   Int       @default(0)
  isPriority    Boolean   @default(false)
  status        ConvStatus @default(ACTIVE)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      Message[]

  @@index([userId])
  @@index([lastMessageAt])
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  LOCKED_IMAGE
  LOCKED_VIDEO
  TIP
}

enum ConvStatus {
  ACTIVE
  ARCHIVED
  SPAM
}

model PrivateRequest {
  id          String              @id @default(cuid())
  userId      String
  orderNumber String              @unique
  type        PrivateRequestType
  description String
  budget      Float?
  status      PrivateRequestStatus @default(PENDING)
  adminNotes  String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
}

// Enums

enum Role {
  USER
  ADMIN
}

enum SubscriptionTier {
  VOYEUR
  INITIE
  PRIVILEGE
  SKYCLUB
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  EXPIRED
}

enum TransactionType {
  SKYCOINS_PURCHASE
  SKYCOINS_SPEND
  SUBSCRIPTION_PAYMENT
  REFUND
  LOGIN_BONUS
  MISSION_REWARD
  GAME_REWARD
  REFERRAL_BONUS
  REWARD_REDEEM
}

enum ContentType {
  VIDEO
  PHOTO
  SERIES
  COLLABORATION
}

enum MessageSender {
  USER
  MILAN
}

enum PrivateRequestType {
  VIDEO
  PHOTO
  CALL
  CUSTOM
}

enum PrivateRequestStatus {
  PENDING
  VALIDATED
  PAID
  IN_PROGRESS
  DELIVERED
  CANCELLED
}

model Quotidirty {
  id              String           @id @default(cuid())
  title           String
  description     String?
  type            ContentType      @default(PHOTO)
  mediaUrl        String
  imageUrl        String
  price           Int              @default(0) // Price in SkyCoins
  tier            SubscriptionTier @default(VOYEUR)
  releaseTime     DateTime
  expireTime      DateTime
  isActive        Boolean          @default(true)
  mode            ThemeMode        @default(NOCTUA)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relationships
  purchases QuotidirtyPurchase[]
}

model QuotidirtyPurchase {
  id           String     @id @default(cuid())
  userId       String
  quotidirtyId String
  purchasedAt  DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  quotidirty   Quotidirty @relation(fields: [quotidirtyId], references: [id], onDelete: Cascade)

  @@unique([userId, quotidirtyId])
}
enum PaymentStatus {
  PENDING
  VALIDATED
  REJECTED
}

enum ManualPaymentType {
  SUBSCRIPTION
  SKYCOINS
}

model ManualPaymentRequest {
  id              String            @id @default(cuid())
  userId          String
  type            ManualPaymentType
  targetId        String            // Tier name (e.g., 'INITIE') or Pack ID (e.g., 'plus')
  amount          Float
  method          String            // 'REVOLUT', 'PAYPAL', 'CRYPTO'
  proofImageUrl   String?           // Screenshot URL from Cloudinary
  status          PaymentStatus     @default(PENDING)
  adminNotes      String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Game {
  id          String      @id @default(cuid())
  title       String
  description String?
  type        String      // e.g., 'QUIZ', 'ADVENTURE'
  imageUrl    String?
  mediaUrl    String?     // Link to game engine/iframe or asset
  mode        ThemeMode   @default(NOCTUA)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// -----------------------------------------------------------------------------
// Gamification & Loyalty Models 
// -----------------------------------------------------------------------------

model DailyLogin {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  bonus     Int      @default(2)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model MissionCompletion {
  id          String   @id @default(cuid())
  userId      String
  missionKey  String   // e.g., "watch_2_videos", "play_game", "send_message"
  reward      Int
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, missionKey, completedAt])
  @@index([userId])
}
